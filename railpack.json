{
  "$schema": "https://schema.railpack.com",
  "provider": "node",
  "buildAptPackages": ["python3", "python3-pip", "build-essential", "pkg-config", "make"],
  "packages": {
    "node": "18"
  },
  "deploy": {
    "startCommand": "PORT=${PORT:-3001} node dist/index.js",
    "variables": {
      "PORT": "3001",
      "NODE_ENV": "production"
    }
  }
}
